{
  "expo": {
    "name": "Sorting-Hat",
    "slug": "Sorting-Hat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "PriorityApp uses notifications to remind you of your top tasks each day.",
        "NSCalendarsUsageDescription": "PriorityApp reads your calendar so the AI can factor in your schedule when prioritizing tasks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["READ_CALENDAR"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
