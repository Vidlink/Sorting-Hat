# Copy this file to .env and fill in your Supabase project values.
# Expo SDK 49+ requires the EXPO_PUBLIC_ prefix to expose variables to the JS bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI — used by voiceService.ts for Whisper transcription
# ⚠️  For production, proxy this through your backend instead of shipping it in the app bundle.
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-api-key-here
